# WorstAssume — Environment Configuration
# Copy this file to .env and fill in values as needed.
# The .env file is git-ignored; this file is safe to commit.

# ─── AWS Credentials (alternative to mounting ~/.aws in Docker) ───────────────
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_SESSION_TOKEN=...
# AWS_DEFAULT_REGION=us-east-1

# ─── Database path ────────────────────────────────────────────────────────────
# Default: ~/.worstassume/db.sqlite
# WORSTASSUME_DB=/data/db.sqlite

# ─── Viz server ───────────────────────────────────────────────────────────────
# WORSTASSUME_HOST=127.0.0.1
# WORSTASSUME_PORT=3000
